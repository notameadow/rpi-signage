# /etc/signage-backup.env — operator-supplied destination for off-box backups.
# Copy to /etc/signage-backup.env (root, 0600) and fill in the values for
# your environment. Sourced by signage-backup.service via EnvironmentFile=.
#
# Required: REMOTE_USER, REMOTE_HOST, REMOTE_PORT, REMOTE_BASE.
# Optional: REMOTE_KEY (default: /home/dev/.ssh/id_ed25519_backup),
#           RETAIN_DAYS (default: 30).

REMOTE_USER=
REMOTE_HOST=
REMOTE_PORT=22
REMOTE_BASE=
REMOTE_KEY=/home/dev/.ssh/id_ed25519_backup
RETAIN_DAYS=30
