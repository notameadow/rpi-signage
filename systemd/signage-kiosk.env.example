# /etc/default/signage-kiosk — kiosk output assignment.
# Sourced by toolchain/kiosk.sh. Only relevant on Pi 5 (two HDMI ports);
# Pi 4 has a single HDMI and the script auto-falls-back to whatever is
# present, so this file can be left at defaults or deleted there.
#
# SIGNAGE_OUTPUT           the wlr-randr output name that should show the
#                           slideshow. Pi 5 typical names: HDMI-A-1 /
#                           HDMI-A-2 (the labels next to each port on the
#                           board map 1:1).
# BLANK_OUTPUT             comma-separated list of outputs to force off at
#                           kiosk start. Reserved for the future playout
#                           subsystem so signage doesn't accidentally
#                           mirror to it.
# SIGNAGE_OUTPUT_IDENTITY  optional EDID-substring lock. If set, the
#                           connected display on SIGNAGE_OUTPUT must match
#                           this substring (against Make+Model+Serial as
#                           reported by wlr-randr) or the kiosk refuses
#                           to render. Use this to bind signage to a
#                           specific physical screen so a wrong cable
#                           swap doesn't redirect content elsewhere.
#                           Capture the current value with:
#                             WAYLAND_DISPLAY=wayland-0 \
#                             XDG_RUNTIME_DIR=/run/user/1000 \
#                             wlr-randr | head -1
#                           and copy the quoted "Make Model Serial" portion.

SIGNAGE_OUTPUT=HDMI-A-1
BLANK_OUTPUT=HDMI-A-2
# Example (uncomment + replace with your captured value — keep the quotes):
#SIGNAGE_OUTPUT_IDENTITY="LG Electronics LG TV 0x01010101"
